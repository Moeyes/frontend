'use client';
import { PageErrorState } from '@/shared/ui/page/PageErrorState';

export default function Error({
  error,
  reset,
}: {
  error: Error & { digest?: string };
  reset: () => void;
}) {
  return <PageErrorState error={error} onRetry={reset} />;
}
