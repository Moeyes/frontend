# Frontend environment variables
# Copy this file to .env.local and fill in the values

# Browser API calls use relative /api paths through the Next.js proxy.
NEXT_PUBLIC_API_URL=

# Optional: Public URL of this frontend app (defaults to http://localhost:3000)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Cloudinary cloud name for image uploads
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
